#!/usr/bin/env bash
# omarchy-starship-preset
# Interactive fzf picker to browse, preview, and apply starship.toml presets.
#
# Sources:
#   [preset]  Built-in starship presets  (starship preset --list)
#   [theme]   Omarchy themes rendered from colors.toml + starship.toml.tpl
#
# Usage:
#   omarchy-starship-preset                  # interactive fzf picker
#   omarchy-starship-preset --preview-only <name>   # print preset TOML to stdout

set -euo pipefail

# ─── paths ────────────────────────────────────────────────────────────────────

LIVE_CONFIG="$HOME/.config/omarchy/current/theme/starship.toml"
OMARCHY_THEMES="$HOME/.local/share/omarchy/themes"
USER_THEMES="$HOME/.config/omarchy/themes"
TEMPLATE="$HOME/.local/share/omarchy/default/themed/starship.toml.tpl"
export TMPDIR_PRESETS
TMPDIR_PRESETS="$(mktemp -d /tmp/omarchy-starship-preset.XXXXXX)"
trap 'rm -rf "$TMPDIR_PRESETS"' EXIT

# ─── helpers ──────────────────────────────────────────────────────────────────

has() { command -v "$1" &>/dev/null; }

_bat_toml() {
  local file="$1"
  if has bat; then
    bat --language toml --color=always --style=plain "$file" 2>/dev/null
  else
    cat "$file"
  fi
}

# Build a sed substitution script from a colors.toml file (same logic as
# omarchy-theme-set-templates so the rendered output is identical).
build_sed_script() {
  local colors_file="$1" out="$2"
  hex_to_rgb() {
    local hex="${1#\#}"
    printf "%d,%d,%d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
  }
  while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"
    printf 's|{{ %s }}|%s|g\n'       "$key" "$value"
    printf 's|{{ %s_strip }}|%s|g\n' "$key" "${value#\#}"
    if [[ $value =~ ^# ]]; then
      printf 's|{{ %s_rgb }}|%s|g\n' "$key" "$(hex_to_rgb "$value")"
    fi
  done <"$colors_file" >"$out"
}

# Render a pretty preview for an fzf panel: simulated prompt + highlighted TOML.
render_preview() {
  local label="$1" file="$2"
  local name="${label##*]  }"

  printf '\033[1;36m━━━ %s \033[0m\n\n' "$label"

  # Simulate a prompt line using starship itself.
  # STARSHIP_SHELL=fish gives raw ANSI — no %{...%} (zsh) or \[...\] (bash) wrappers.
  if STARSHIP_CONFIG="$file" STARSHIP_SHELL=fish starship prompt \
       --status 0 --jobs 0 \
       --terminal-width "${FZF_PREVIEW_COLUMNS:-80}" 2>/dev/null; then
    printf '\n\033[38;5;240m──────────────────────────────────────────────────\033[0m\n\n'
  fi

  _bat_toml "$file"
}

# ─── --render-preview (self-invoked by fzf --preview) ─────────────────────────

if [[ "${1:-}" == "--render-preview" ]]; then
  render_preview "$3" "$2"
  exit 0
fi

# ─── --preview-only <name> (non-interactive / scripting mode) ─────────────────

if [[ "${1:-}" == "--preview-only" ]]; then
  [[ -z "${2:-}" ]] && { echo "Usage: omarchy-starship-preset --preview-only <name>" >&2; exit 1; }
  name="$2"
  outfile="$TMPDIR_PRESETS/preview.toml"
  if starship preset "$name" -o "$outfile" 2>/dev/null; then
    cat "$outfile"
    exit 0
  fi
  printf 'Preset "%s" not found.\nAvailable presets:\n' "$name" >&2
  starship preset --list >&2
  exit 1
fi

# ─── build item list ──────────────────────────────────────────────────────────
# Each entry is:  "<display-label>\t<toml-file-path>"

entries=()

# Source A ── built-in starship presets
while IFS= read -r preset; do
  [[ -z "$preset" ]] && continue
  outfile="$TMPDIR_PRESETS/preset-${preset}.toml"
  if starship preset "$preset" -o "$outfile" 2>/dev/null; then
    entries+=("[preset]  ${preset}"$'\t'"${outfile}")
  fi
done < <(starship preset --list 2>/dev/null)

# Source B ── omarchy themes rendered from colors.toml + template
if [[ -f "$TEMPLATE" ]]; then
  # Collect unique theme dirs (user themes override stock)
  declare -A seen_themes=()
  for theme_dir in "$USER_THEMES"/*/ "$OMARCHY_THEMES"/*/; do
    [[ -d "$theme_dir" ]] || continue
    theme_name="$(basename "$theme_dir")"
    [[ -n "${seen_themes[$theme_name]:-}" ]] && continue
    seen_themes[$theme_name]=1

    outfile="$TMPDIR_PRESETS/theme-${theme_name}.toml"

    if [[ -f "${theme_dir}starship.toml" ]]; then
      # Theme ships its own starship.toml — use it directly
      cp "${theme_dir}starship.toml" "$outfile"
      entries+=("[theme]   ${theme_name}"$'\t'"${outfile}")
    elif [[ -f "${theme_dir}colors.toml" ]]; then
      # Render from template + colors palette (same as omarchy-theme-set-templates)
      sed_script="$(mktemp)"
      build_sed_script "${theme_dir}colors.toml" "$sed_script"
      sed -f "$sed_script" "$TEMPLATE" >"$outfile"
      rm "$sed_script"
      entries+=("[theme]   ${theme_name}"$'\t'"${outfile}")
    fi
  done
fi

if [[ ${#entries[@]} -eq 0 ]]; then
  echo "No presets found." >&2
  exit 1
fi

# ─── fzf picker ───────────────────────────────────────────────────────────────

if ! has fzf; then
  echo "fzf is required but not installed (sudo pacman -S fzf)." >&2
  exit 1
fi

SCRIPT_PATH="$(realpath "$0")"

selection="$(
  printf '%s\n' "${entries[@]}" \
  | fzf \
      --delimiter=$'\t' \
      --with-nth=1 \
      --preview="$SCRIPT_PATH --render-preview {2} {1}" \
      --preview-window='right:60%:wrap' \
      --header='  ↑↓ navigate   Enter select   Esc quit' \
      --header-first \
      --prompt='  starship preset › ' \
      --ansi \
      --no-multi
)" || exit 0

[[ -z "$selection" ]] && exit 0

label="${selection%%$'\t'*}"
file="${selection##*$'\t'}"

# ─── post-selection action menu ───────────────────────────────────────────────

printf '\n\033[1;33m  Selected:\033[0m %s\n\n' "$label"

while true; do
  printf '  [\033[1ms\033[0m]ave to current theme'
  printf '   [\033[1mt\033[0m]est in new shell'
  printf '   [\033[1md\033[0m]iff vs current'
  printf '   [\033[1mq\033[0m]uit\n  › '
  read -r -n1 choice
  printf '\n'

  case "$choice" in
    s|S)
      backup="${LIVE_CONFIG}.bak.$(date +%Y%m%d%H%M%S)"
      cp "$LIVE_CONFIG" "$backup"
      cp "$file" "$LIVE_CONFIG"
      printf '\n  \033[1;32m✓ Saved.\033[0m Backup → %s\n\n' "$backup"
      break
      ;;
    t|T)
      printf '\n  \033[1;36m→ Opening test shell\033[0m (type "exit" to return)...\n\n'
      # starship.zsh in zsh init always re-exports STARSHIP_CONFIG to the live
      # path, so passing the env var is silently overwritten. Instead, swap the
      # preset into the live file for the duration of the test shell, then
      # restore.  Backup lives in TMPDIR_PRESETS so it's cleaned up on EXIT.
      live_backup="$TMPDIR_PRESETS/live.bak"
      cp "$LIVE_CONFIG" "$live_backup"
      cp "$file" "$LIVE_CONFIG"
      zsh
      cp "$live_backup" "$LIVE_CONFIG"
      printf '\n  \033[38;5;240m(restored original starship.toml)\033[0m\n\n'
      ;;
    d|D)
      printf '\n'
      diff --color=always "$LIVE_CONFIG" "$file" \
        && printf '  \033[38;5;240m(no differences)\033[0m\n' \
        || true
      printf '\n'
      ;;
    q|Q|$'\x1b'|'')
      printf '  Quit.\n'
      break
      ;;
  esac
done
