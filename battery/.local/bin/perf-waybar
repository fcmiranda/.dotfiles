#!/usr/bin/env bash
# perf-waybar — waybar output script for custom/perf module
# Reads the cpufreq scaling_governor (Apple Silicon / Asahi Linux).
# Empty output when on the default balanced governor (schedutil).

# Read governor from any available policy
gov=$(cat /sys/devices/system/cpu/cpufreq/policy5/scaling_governor \
         /sys/devices/system/cpu/cpufreq/policy0/scaling_governor \
      2>/dev/null | head -1)

case "$gov" in
  performance)                printf '󰓅 PERF' ;;
  powersave|conservative)     printf '󰌪 ECO'  ;;
  schedutil|ondemand|userspace|"") printf ''  ;;
  *)                          printf '%s' "$gov" ;;
esac
