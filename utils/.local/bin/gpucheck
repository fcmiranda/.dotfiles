#!/usr/bin/env bash
# gpucheck - GPU, driver, and energy performance diagnostics
# Usage: gpucheck [--fix] [--watch] [--help]

set -uo pipefail

# ── Colors ─────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# ── Defaults ───────────────────────────────────────────────────────────────────
FIX_MODE=false
WATCH_MODE=false

# ── Args ───────────────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case $1 in
    --fix|-f)    FIX_MODE=true ;;
    --watch|-w)  WATCH_MODE=true ;;
    --help|-h)
      echo "Usage: gpucheck [--fix] [--watch]"
      echo "  --fix    Apply quick remediations (CPU governor, NVIDIA persistence mode)"
      echo "  --watch  Refresh every 3s (Ctrl+C to exit)"
      exit 0 ;;
    *) echo "Unknown option: $1. Use --help"; exit 1 ;;
  esac
  shift
done

# ── Helpers ────────────────────────────────────────────────────────────────────
draw_bar() {
  local pct=$1 width=${2:-20}
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local color bar_str=""
  (( pct >= 85 )) && color=$RED || { (( pct >= 60 )) && color=$YELLOW || color=$GREEN; }
  local i
  for (( i=0; i<filled; i++ )); do bar_str+="█"; done
  for (( i=0; i<empty;  i++ )); do bar_str+="░"; done
  printf "${color}%s${RESET}" "$bar_str"
}

ok()   { printf "  ${GREEN}${BOLD}✓${RESET}  %s\n" "$*"; }
warn() { printf "  ${YELLOW}${BOLD}⚠${RESET}  %s\n" "$*"; }
crit() { printf "  ${RED}${BOLD}✗${RESET}  %s\n" "$*"; }
info() { printf "  ${DIM}·${RESET}  %s\n" "$*"; }

section() { printf "\n${BOLD}${CYAN}══ %s %s${RESET}\n" "$1" "$(printf '═%.0s' $(seq 1 $(( 60 - ${#1} )) 2>/dev/null || true))"; }

# ── Section 0: Resolve 'exe' mystery processes ─────────────────────────────────
print_exe_resolver() {
  local exe_pids
  mapfile -t exe_pids < <(ps -eo pid,comm | awk '$2 == "exe" {print $1}')

  if (( ${#exe_pids[@]} == 0 )); then
    return
  fi

  section "UNIDENTIFIED 'exe' PROCESSES"
  printf "${BOLD}  %-8s %-10s %-10s  %s${RESET}\n" "PID" "RSS" "MEM%" "FULL PATH"
  printf "${DIM}  %s${RESET}\n" "──────────────────────────────────────────────────────────────"

  local pid rss_kb rss_h mem_pct cmdline app_name color
  for pid in "${exe_pids[@]}"; do
    rss_kb=$(awk '/^VmRSS/{print $2}' /proc/"$pid"/status 2>/dev/null || echo 0)
    rss_kb=${rss_kb:-0}
    mem_pct=$(ps -p "$pid" -o pmem= 2>/dev/null | tr -d ' ' || echo "?")

    # Read full cmdline (NUL-separated → space)
    cmdline=""
    if [[ -r /proc/$pid/cmdline ]]; then
      cmdline=$(tr '\0' ' ' < /proc/"$pid"/cmdline 2>/dev/null | sed 's/ $//')
    fi
    [[ -z "$cmdline" ]] && cmdline="(unreadable — need root)"

    # Extract friendly app name from path
    app_name=$(echo "$cmdline" | grep -oP '[^/\s]+(?=/exe\b)' | tail -1)
    [[ -z "$app_name" ]] && app_name=$(echo "$cmdline" | awk '{print $1}' | xargs basename 2>/dev/null)

    local kb_int=${rss_kb%%[^0-9]*}
    kb_int=${kb_int:-0}
    local rss_mb=$(( kb_int / 1024 ))
    (( rss_mb > 200 )) && color=$RED || { (( rss_mb > 80 )) && color=$YELLOW || color=$RESET; }

    printf "${color}  %-8s %-10s %-10s  %s${RESET}\n" \
      "$pid" "${rss_mb} MB" "${mem_pct}%" "${cmdline:0:80}"

    if [[ -n "$app_name" && "$app_name" != "exe" ]]; then
      info "  → identified as: ${BOLD}${app_name}${RESET}"
    fi
  done
}

# ── Section 1: NVIDIA Driver ────────────────────────────────────────────────────
HAS_NVIDIA=false
GPU_NAME=""
DRIVER_VERSION=""

print_nvidia_driver() {
  section "NVIDIA DRIVER"

  if ! command -v nvidia-smi &>/dev/null; then
    warn "nvidia-smi not found — NVIDIA driver not installed or not in PATH"
    return
  fi

  HAS_NVIDIA=true

  # Driver version and GPU name
  DRIVER_VERSION=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1)
  GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)

  printf "  ${BOLD}GPU     :${RESET} %s\n" "${GPU_NAME:-unknown}"
  printf "  ${BOLD}Driver  :${RESET} %s\n" "${DRIVER_VERSION:-unknown}"

  # Hybrid GPU check via supergfxctl (ASUS ROG / hybrid systems)
  if command -v supergfxctl &>/dev/null; then
    local gfx_mode
    gfx_mode=$(supergfxctl -s 2>/dev/null || echo "unknown")
    printf "  ${BOLD}GPU Mode:${RESET} "
    case "$gfx_mode" in
      Hybrid)      printf "${GREEN}Hybrid (iGPU primary, dGPU on-demand)${RESET}\n" ;;
      Dedicated)   printf "${YELLOW}Dedicated (dGPU always active — max power draw)${RESET}\n" ;;
      Integrated)  printf "${CYAN}Integrated only (dGPU off — max battery)${RESET}\n" ;;
      Vfio)        printf "${DIM}VFIO (GPU passed to VM)${RESET}\n" ;;
      *)           printf "${DIM}%s${RESET}\n" "$gfx_mode" ;;
    esac
  fi

  # Try lspci detection if supergfxctl absent
  if ! command -v supergfxctl &>/dev/null; then
    local gpu_count
    gpu_count=$(lspci | grep -cE 'VGA|3D|Display' 2>/dev/null || echo 1)
    if (( gpu_count > 1 )); then
      info "Hybrid GPU detected via lspci ($gpu_count display adapters) — install supergfxctl for mode control"
    fi
  fi
}

# ── Section 2: NVIDIA Performance State & Clocks ───────────────────────────────
NVIDIA_PSTATE=""
GPU_UTIL=0
DIAG_PSTATE_WARN=false
DIAG_CLOCKS_WARN=false

print_nvidia_perf() {
  $HAS_NVIDIA || return
  section "NVIDIA PERFORMANCE STATE"

  local raw
  raw=$(nvidia-smi \
    --query-gpu=pstate,utilization.gpu,clocks.current.graphics,clocks.max.graphics,clocks.current.memory,clocks.max.memory \
    --format=csv,noheader,nounits 2>/dev/null) || { warn "nvidia-smi query failed"; return; }

  IFS=',' read -r pstate gpu_util gfx_cur gfx_max mem_cur mem_max <<< "$raw"
  pstate=$(echo "$pstate" | tr -d ' ')
  gpu_util=$(echo "$gpu_util" | tr -d ' ')
  gfx_cur=$(echo "$gfx_cur" | tr -d ' ')
  gfx_max=$(echo "$gfx_max" | tr -d ' ')
  mem_cur=$(echo "$mem_cur" | tr -d ' ')
  mem_max=$(echo "$mem_max" | tr -d ' ')

  NVIDIA_PSTATE="$pstate"
  # Strip [N/A] or any non-numeric value from nvidia-smi
  [[ "$gpu_util" =~ ^[0-9]+$ ]] && GPU_UTIL=$gpu_util || GPU_UTIL=0

  # Performance state: P0 = max performance
  printf "  ${BOLD}P-State :${RESET} "
  if [[ "$pstate" == "P0" ]]; then
    printf "${GREEN}${BOLD}P0 — MAX performance${RESET}\n"
  elif [[ "$pstate" =~ ^P([0-9]+)$ ]]; then
    local lvl="${BASH_REMATCH[1]}"
    printf "${YELLOW}${BOLD}%s — throttled (level %s, P0 = max)${RESET}\n" "$pstate" "$lvl"
    DIAG_PSTATE_WARN=true
  else
    printf "${DIM}%s${RESET}\n" "$pstate"
  fi

  printf "  ${BOLD}GPU Util:${RESET} %s%%\n" "${GPU_UTIL}"

  # Graphics clock bar
  if [[ "$gfx_cur" =~ ^[0-9]+$ && "$gfx_max" =~ ^[0-9]+$ && "$gfx_max" != "0" ]]; then
    local gfx_pct=$(( gfx_cur * 100 / gfx_max ))
    printf "  ${BOLD}GFX Clk :${RESET} [%s] %s / %s MHz (%d%%)\n" \
      "$(draw_bar $gfx_pct)" "$gfx_cur" "$gfx_max" "$gfx_pct"
    (( gfx_pct < 80 && GPU_UTIL > 30 )) && DIAG_CLOCKS_WARN=true
  fi

  # Memory clock bar
  if [[ "$mem_cur" =~ ^[0-9]+$ && "$mem_max" =~ ^[0-9]+$ && "$mem_max" != "0" ]]; then
    local mem_pct=$(( mem_cur * 100 / mem_max ))
    printf "  ${BOLD}MEM Clk :${RESET} [%s] %s / %s MHz (%d%%)\n" \
      "$(draw_bar $mem_pct)" "$mem_cur" "$mem_max" "$mem_pct"
  fi
}

# ── Section 3: NVIDIA Power Draw ───────────────────────────────────────────────
DIAG_PERSISTENCE_WARN=false

print_nvidia_power() {
  $HAS_NVIDIA || return
  section "NVIDIA POWER"

  local raw
  raw=$(nvidia-smi \
    --query-gpu=power.draw,power.limit,power.management,persistence_mode,temperature.gpu \
    --format=csv,noheader,nounits 2>/dev/null) || { warn "nvidia-smi query failed"; return; }

  IFS=',' read -r pwr_draw pwr_limit pwr_mgmt persist_mode temp_gpu <<< "$raw"
  pwr_draw=$(echo "$pwr_draw" | tr -d ' ')
  pwr_limit=$(echo "$pwr_limit" | tr -d ' ')
  pwr_mgmt=$(echo "$pwr_mgmt" | tr -d ' ')
  persist_mode=$(echo "$persist_mode" | tr -d ' ')
  temp_gpu=$(echo "$temp_gpu" | tr -d ' ')

  # Power draw bar
  if [[ "$pwr_draw" =~ ^[0-9]+(\.[0-9]+)?$ && "$pwr_limit" =~ ^[0-9]+(\.[0-9]+)?$ && "$pwr_limit" != "0.00" ]]; then
    local pwr_pct
    pwr_pct=$(awk "BEGIN {printf \"%d\", ($pwr_draw / $pwr_limit) * 100}" 2>/dev/null || echo 0)
    printf "  ${BOLD}Power   :${RESET} [%s] %.1f / %.1f W (%d%%)\n" \
      "$(draw_bar $pwr_pct)" "$pwr_draw" "$pwr_limit" "$pwr_pct"
  fi

  # Temperature
  if [[ "$temp_gpu" =~ ^[0-9]+$ ]]; then
    printf "  ${BOLD}Temp    :${RESET} "
    if (( temp_gpu >= 85 )); then
      printf "${RED}${BOLD}%s°C — HOT${RESET}\n" "$temp_gpu"
    elif (( temp_gpu >= 70 )); then
      printf "${YELLOW}%s°C — warm${RESET}\n" "$temp_gpu"
    else
      printf "${GREEN}%s°C — OK${RESET}\n" "$temp_gpu"
    fi
  fi

  # Power management (only if not N/A)
  [[ "$pwr_mgmt" =~ ^\[N\/A\]$ ]] || printf "  ${BOLD}Pwr Mgmt:${RESET} %s\n" "$pwr_mgmt"

  # Persistence mode
  printf "  ${BOLD}Persist :${RESET} "
  if [[ "$persist_mode" == "Enabled" ]]; then
    printf "${GREEN}Enabled${RESET} — GPU stays loaded, lower launch latency\n"
  else
    printf "${DIM}Disabled${RESET} — GPU unloads when idle (higher cold-start latency)\n"
    DIAG_PERSISTENCE_WARN=true
  fi
}

# ── Section 4: Energy & CPU Throttle ──────────────────────────────────────────
DIAG_BATTERY=false
DIAG_GOVERNOR_WARN=false
DIAG_FREQ_THROTTLE=false
ON_AC=false

print_energy() {
  section "ENERGY & THROTTLE"

  # AC vs Battery detection (same logic as omarchy-powerprofiles-set)
  local power_source="Battery"
  for ps in /sys/class/power_supply/*; do
    [[ -r $ps/online && -r $ps/type ]] || continue
    local ps_type
    ps_type=$(cat "$ps/type")
    [[ $ps_type == "Mains" || $ps_type == "USB" ]] || continue
    if [[ $(cat "$ps/online") == "1" ]]; then
      power_source="AC"
      ON_AC=true
      break
    fi
  done

  printf "  ${BOLD}Source  :${RESET} "
  if $ON_AC; then
    printf "${GREEN}AC${RESET} — no battery throttling expected\n"
  else
    printf "${YELLOW}Battery${RESET} — power profile may limit GPU/CPU\n"
    DIAG_BATTERY=true
  fi

  # Power profile
  if command -v powerprofilesctl &>/dev/null; then
    local profile
    profile=$(powerprofilesctl get 2>/dev/null || echo "unknown")
    printf "  ${BOLD}Profile :${RESET} "
    case "$profile" in
      performance)  printf "${GREEN}performance${RESET}\n" ;;
      balanced)     printf "${YELLOW}balanced${RESET}\n" ;;
      power-saver)  printf "${RED}power-saver${RESET} — CPU/GPU actively throttled\n" ;;
      *)            printf "${DIM}%s${RESET}\n" "$profile" ;;
    esac
  fi

  # CPU governor
  local governor_file="/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor"
  if [[ -r "$governor_file" ]]; then
    local governor
    governor=$(cat "$governor_file")
    printf "  ${BOLD}Governor:${RESET} "
    case "$governor" in
      performance)   printf "${GREEN}performance${RESET}\n" ;;
      ondemand|schedutil) printf "${YELLOW}%s${RESET} — dynamic scaling (OK for most workloads)\n" "$governor" ;;
      powersave)     printf "${RED}powersave${RESET} — CPU pinned to minimum frequency\n"; DIAG_GOVERNOR_WARN=true ;;
      *)             printf "${DIM}%s${RESET}\n" "$governor" ;;
    esac
  fi

  # CPU frequency: average current vs max across all CPUs
  local cur_sum=0 max_sum=0 cpu_count=0
  for cpu_dir in /sys/devices/system/cpu/cpu[0-9]*/cpufreq; do
    [[ -r $cpu_dir/scaling_cur_freq && -r $cpu_dir/cpuinfo_max_freq ]] || continue
    local cur max
    cur=$(cat "$cpu_dir/scaling_cur_freq")
    max=$(cat "$cpu_dir/cpuinfo_max_freq")
    (( cur_sum += cur, max_sum += max, cpu_count++ ))
  done

  if (( cpu_count > 0 )); then
    local avg_cur=$(( cur_sum / cpu_count ))
    local avg_max=$(( max_sum / cpu_count ))
    local freq_pct=$(( avg_cur * 100 / avg_max ))
    local avg_cur_mhz=$(( avg_cur / 1000 ))
    local avg_max_mhz=$(( avg_max / 1000 ))
    printf "  ${BOLD}CPU Freq:${RESET} [%s] %d / %d MHz (%d%%, avg over %d cores)\n" \
      "$(draw_bar $freq_pct)" "$avg_cur_mhz" "$avg_max_mhz" "$freq_pct" "$cpu_count"
    (( freq_pct < 50 )) && DIAG_FREQ_THROTTLE=true
  fi

  # Battery capacity if on battery
  if ! $ON_AC; then
    for bat in /sys/class/power_supply/BAT*; do
      [[ -r $bat/capacity ]] || continue
      local cap
      cap=$(cat "$bat/capacity")
      printf "  ${BOLD}Battery :${RESET} %d%%\n" "$cap"
    done
  fi
}

# ── Section 5: Diagnostics summary ────────────────────────────────────────────
print_diagnostics() {
  section "DIAGNOSTICS"

  local any_warn=false

  if $DIAG_PSTATE_WARN; then
    if (( GPU_UTIL > 20 )); then
      warn "NVIDIA in ${NVIDIA_PSTATE} while utilization is ${GPU_UTIL}% — GPU is active but not at max performance (P0)."
    else
      info "NVIDIA in ${NVIDIA_PSTATE} — GPU is idle (${GPU_UTIL}% util). Will jump to P0 automatically under load."
    fi
    any_warn=true
  fi

  if $DIAG_CLOCKS_WARN; then
    warn "GPU clocks below max while utilization is high — possible thermal or power throttling."
    any_warn=true
  fi

  if $DIAG_PERSISTENCE_WARN; then
    info "NVIDIA persistence mode is off. Enable for lower launch latency: ${BOLD}sudo nvidia-smi -pm 1${RESET}"
    any_warn=true
  fi

  if $DIAG_GOVERNOR_WARN; then
    warn "CPU governor is 'powersave' — CPUs are pinned to minimum frequency. Fix with: ${BOLD}sudo cpupower frequency-set -g performance${RESET}"
    any_warn=true
  fi

  # Only flag freq throttle if governor is 'performance' (should never scale down)
  if $DIAG_FREQ_THROTTLE && ! $DIAG_GOVERNOR_WARN; then
    local gov
    gov=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "")
    if [[ "$gov" == "performance" ]]; then
      warn "CPU governor is 'performance' but frequency is below 50% of max — possible thermal throttle."
      any_warn=true
    fi
  fi

  if $DIAG_BATTERY; then
    warn "On battery — NVIDIA dGPU and CPU may be throttled by power profile. Plug in AC for max performance."
    any_warn=true
  fi

  if ! $any_warn; then
    ok "No performance issues detected — system running at full capacity."
  fi
}

# ── Section 6: Apply fixes ─────────────────────────────────────────────────────
apply_fixes() {
  section "APPLYING FIXES"

  # CPU governor
  if $DIAG_GOVERNOR_WARN; then
    printf "\n"
    warn "CPU governor is 'powersave'."
    printf "  Apply fix? Set all CPUs to 'performance' governor. [y/N] "
    read -r ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      if command -v cpupower &>/dev/null; then
        sudo cpupower frequency-set -g performance && ok "CPU governor set to 'performance'." || crit "Failed to set CPU governor."
      else
        crit "cpupower not found. Install it: ${BOLD}sudo pacman -S cpupower${RESET}"
      fi
    fi
  fi

  # NVIDIA persistence mode
  if $DIAG_PERSISTENCE_WARN && $HAS_NVIDIA; then
    printf "\n"
    info "NVIDIA persistence mode is off."
    printf "  Enable it now? (lower GPU cold-start latency) [y/N] "
    read -r ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      sudo nvidia-smi -pm 1 && ok "NVIDIA persistence mode enabled." || crit "Failed to enable persistence mode."
    fi
  fi
}

# ── Main ───────────────────────────────────────────────────────────────────────
run_once() {
  clear 2>/dev/null || true
  printf "${BOLD}${CYAN}gpucheck${RESET} — GPU & performance diagnostics  ${DIM}$(date '+%H:%M:%S')${RESET}\n"

  print_exe_resolver
  print_nvidia_driver
  print_nvidia_perf
  print_nvidia_power
  print_energy
  print_diagnostics

  if $FIX_MODE; then
    apply_fixes
  else
    printf "\n${DIM}Tip: run with --fix to apply quick remediations${RESET}\n"
  fi
  printf "\n"
}

if $WATCH_MODE; then
  while true; do
    run_once
    printf "${DIM}Refreshing in 3s… Ctrl+C to exit${RESET}\n"
    sleep 3
  done
else
  run_once
fi
