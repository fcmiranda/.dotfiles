#!/bin/bash

set -u

selection="$(/usr/bin/sesh list -d -c -t -T -z 2>/dev/null | fuzzel --dmenu --placeholder "Sesh…" --width 60 --lines 15 --minimal-lines)"

if [[ -z "$selection" ]]; then
  exit 0
fi

/usr/bin/sesh connect --switch -- "$selection" 2>/dev/null && exit 0
exec /usr/bin/uwsm-app -- /usr/bin/xdg-terminal-exec -e /usr/bin/sesh connect -- "$selection"
