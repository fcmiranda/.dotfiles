@import "style.css.default";

/* Make the main bar background transparent */
window#waybar {
  background: transparent;
}

/* Center spacer configuration */
#custom-notch-spacer {
  background: transparent;
  border: none;
  min-width: 200px; /* Adjusted for 14" MacBook Pro Notch width */
  padding: 0;
  margin: 0;
}


window#waybar.top .modules-right {
  padding: 0 20px 0 0;
}
