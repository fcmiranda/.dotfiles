#!/usr/bin/env bash
# stow-it - Adopt any file or directory into the dotfiles repo and stow it
#
# Usage:
#   stow-it <path> [package]
#
# Examples:
#   stow-it ~/.config/foo/bar.conf           # auto-detects or prompts for package
#   stow-it ~/.config/foo/bar.conf mypkg     # adopt into an existing/new package
#   stow-it ~/.local/share/icons/foo.png     # works with any path under ~/
#
# What it does:
#   1. Resolves the real path of the target file/directory
#   2. Determines the relative path from $HOME
#   3. Moves the file into ~/.dotfiles/<package>/<rel_path>
#   4. Runs stow.sh -a <package> to adopt and create the symlink
#   5. Verifies the symlink was created correctly

set -uo pipefail

# ── Config ────────────────────────────────────────────────────────────────────
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
die()  { echo -e "${RED}${BOLD}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${BLUE}${BOLD}=>${RESET} $*"; }
ok()   { echo -e "${GREEN}${BOLD}✓${RESET}  $*"; }
warn() { echo -e "${YELLOW}${BOLD}!${RESET}  $*"; }

usage() {
  echo "Usage: stow-it <path> [package]"
  echo ""
  echo "Adopt a file or directory into the dotfiles repo and stow it."
  echo ""
  echo "Arguments:"
  echo "  <path>      Absolute or relative path to the file/dir to adopt"
  echo "  [package]   Dotfiles package name (prompted if omitted)"
  echo ""
  echo "Examples:"
  echo "  stow-it ~/.config/kitty/kitty.conf"
  echo "  stow-it ~/.local/share/applications/foo.desktop apps"
  exit 0
}

# ── Args ──────────────────────────────────────────────────────────────────────
[[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]] && usage

TARGET_PATH="$1"
PACKAGE="${2:-}"

# ── Resolve path ──────────────────────────────────────────────────────────────
# Expand ~ manually in case it wasn't expanded by the shell
TARGET_PATH="${TARGET_PATH/#\~/$HOME}"

# Follow symlinks to find the real file, but keep the original location for
# the symlink path we need to recreate
if [[ -L "$TARGET_PATH" ]]; then
  die "'$TARGET_PATH' is already a symlink. Nothing to adopt."
fi

[[ -e "$TARGET_PATH" ]] || die "Path does not exist: $TARGET_PATH"

# Must live under HOME
case "$TARGET_PATH" in
  "$HOME"/*) ;;
  *) die "Path must be under \$HOME ($HOME). Got: $TARGET_PATH" ;;
esac

# Relative path from HOME (e.g. .config/foo/bar.conf)
REL_PATH="${TARGET_PATH#$HOME/}"

# ── Pick a package ────────────────────────────────────────────────────────────
if [[ -z "$PACKAGE" ]]; then
  # Show existing packages for convenience
  echo -e "${DIM}Existing packages in $DOTFILES_DIR:${RESET}"
  for d in "$DOTFILES_DIR"/*/; do
    name="$(basename "$d")"
    [[ "$name" == .* || "$name" == scripts ]] && continue
    echo -e "  ${DIM}·${RESET} $name"
  done
  echo ""
  printf "${BOLD}Package name:${RESET} "
  read -r PACKAGE
fi

[[ -z "$PACKAGE" ]] && die "Package name cannot be empty."

# ── Destination in dotfiles ───────────────────────────────────────────────────
DEST_DIR="$DOTFILES_DIR/$PACKAGE/$(dirname "$REL_PATH")"
DEST_PATH="$DOTFILES_DIR/$PACKAGE/$REL_PATH"

# ── Sanity check ─────────────────────────────────────────────────────────────
if [[ -e "$DEST_PATH" ]]; then
  warn "Destination already exists in dotfiles: $DEST_PATH"
  printf "Overwrite? [y/N] "
  read -r reply
  [[ "$reply" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
  rm -rf "$DEST_PATH"
fi

# ── Move file into dotfiles ──────────────────────────────────────────────────
info "Moving $TARGET_PATH"
info "  → $DEST_PATH"
mkdir -p "$DEST_DIR"
mv "$TARGET_PATH" "$DEST_PATH"

# ── Stow (adopt) ─────────────────────────────────────────────────────────────
info "Stowing package '$PACKAGE'..."
if "$DOTFILES_DIR/stow.sh" -a "$PACKAGE"; then
  # Verify symlink was created
  if [[ -L "$TARGET_PATH" ]]; then
    ok "Symlink verified: $TARGET_PATH → $(readlink "$TARGET_PATH")"
  else
    warn "Stow succeeded but symlink not found at $TARGET_PATH"
    warn "Run: cd ~/.dotfiles && ./stow.sh -r $PACKAGE"
  fi
else
  # Roll back the move so the user isn't left without their file
  warn "Stow failed — rolling back..."
  mv "$DEST_PATH" "$TARGET_PATH"
  die "Adoption failed. File restored to original location."
fi

echo ""
ok "Done. '$REL_PATH' is now tracked in dotfiles package '$PACKAGE'."
echo -e "  ${DIM}Dotfiles path : $DEST_PATH${RESET}"
echo -e "  ${DIM}Live symlink  : $TARGET_PATH${RESET}"
