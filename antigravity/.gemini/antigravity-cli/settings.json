{
  "model": "Gemini 3.1 Pro (Low)",
  "toolPermission": "always-proceed",
  "artifactReviewPolicy": "always-proceed",
  "notifications": true,
  "permissions": {
    "allow": [
      "command(sleep)",
      "command(cargo add async-trait)"
    ]
  },
  "trustedWorkspaces": [
    "/home/fecavmi/.dotfiles/main",
    "/home/fecavmi"
  ],
  "antigravity.commands.alwaysAllow": [
    {
      "pattern": "npm run *",
      "match": "glob"
    },
    {
      "pattern": "git (status|log|diff|branch).*",
      "match": "regex"
    }
  ]
}