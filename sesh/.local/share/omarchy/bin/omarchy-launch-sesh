#!/bin/bash

set -u

if command -v fuzzel &>/dev/null; then
  selection="$(/usr/bin/sesh list -d -c -t -T -z 2>/dev/null | fuzzel --dmenu --placeholder "Sesh…" --width 60 --lines 15 --minimal-lines)"
elif command -v omarchy-launch-walker &>/dev/null; then
  selection="$((/usr/bin/sesh list -d -c -t -T -z 2>/dev/null || true) | omarchy-launch-walker --dmenu --width 720 --minheight 1 --maxheight 620 -p 'Sesh…' 2>/dev/null)"
else
  exit 1
fi

if [[ -z "$selection" ]]; then
  exit 0
fi

/usr/bin/sesh connect --switch -- "$selection" 2>/dev/null && exit 0

# First run often fails when no tmux server/session exists yet.
# Create a default session, retry, then fall back to opening in a terminal.
if ! /usr/bin/tmux has-session -t main 2>/dev/null; then
  /usr/bin/tmux new-session -d -s main 2>/dev/null || true
fi

/usr/bin/sesh connect --switch -- "$selection" 2>/dev/null && exit 0

/usr/bin/uwsm-app -- /usr/bin/xdg-terminal-exec -e /usr/bin/bash -lc \
  '/usr/bin/sesh connect -- "$1" || /usr/bin/tmux new-session -A -s main' _ "$selection"
exit 0
