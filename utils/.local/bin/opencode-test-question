#!/usr/bin/env bash
# =============================================================================
# opencode-test-question — Test harness for opencode question notifications
# =============================================================================
# Exercises all three detection methods of opencode-notify without needing
# a real opencode session or AI call.
#
# Must be run INSIDE tmux.  The typical workflow:
#
#   WINDOW A (where you want to see the notification):
#     → switch to another window after starting the test
#
#   WINDOW B (simulates opencode running here):
#     $ opencode-test-question          # runs full test suite
#     $ opencode-test-question --direct # immediate notification only
#     $ opencode-test-question --log    # trigger via fake log entry
#     $ opencode-test-question --pane   # trigger via fake terminal output
#     $ opencode-test-question --acp    # trigger via fake ACP HTTP server
#
# Options:
#   --direct    Skip detection, immediately fire the notification
#   --log       Write a fake question log entry and let the log watcher find it
#   --pane      Print the question prompt pattern to the terminal and wait
#   --acp       Start a fake ACP HTTP server that emits a question SSE event
#   --all       Run all methods sequentially (default)
#   --question  Custom question text (default: built-in test text)
#   --window    Target window index (default: current window)
#   --session   Target session name  (default: current session)
# =============================================================================

set -uo pipefail

# ─── Defaults ─────────────────────────────────────────────────────────────────
METHOD="all"
QUESTION="Should I use the recursive or iterative approach for this algorithm?"
TARGET_WINDOW=""
TARGET_SESSION=""
NOTIFY_WAIT=3     # seconds to wait before sending each test notification

# ─── Colours ──────────────────────────────────────────────────────────────────
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_CYAN='\033[36m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_DIM='\033[2m'

say()  { printf "${C_BOLD}${C_CYAN}[test]${C_RESET} %s\n" "$*"; }
ok()   { printf "${C_GREEN}  ✓${C_RESET} %s\n" "$*"; }
info() { printf "${C_DIM}  → %s${C_RESET}\n" "$*"; }
warn() { printf "${C_YELLOW}  ! %s${C_RESET}\n" "$*" >&2; }
die()  { printf "\033[31mERROR:\033[0m %s\n" "$*" >&2; exit 1; }

# ─── Parse Args ───────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --direct) METHOD="direct" ;;
    --log)    METHOD="log"    ;;
    --pane)   METHOD="pane"   ;;
    --acp)    METHOD="acp"    ;;
    --all)    METHOD="all"    ;;
    --question)  shift; QUESTION="$1" ;;
    --window)    shift; TARGET_WINDOW="$1" ;;
    --session)   shift; TARGET_SESSION="$1" ;;
    -h|--help)
      sed -n '2,30p' "$0" | sed 's/^# //; s/^#//'
      exit 0
      ;;
    *) die "Unknown option: $1 (run with --help for usage)" ;;
  esac
  shift
done

# ─── Guard: must be inside tmux ───────────────────────────────────────────────
[[ -n "${TMUX:-}" ]] || die "Must be run inside a tmux session"

# ─── Resolve tmux context ─────────────────────────────────────────────────────
PANE_ID=$(tmux display-message -p "#{pane_id}")
[[ -z "$TARGET_WINDOW"  ]] && TARGET_WINDOW=$(tmux display-message -p "#{window_index}")
[[ -z "$TARGET_SESSION" ]] && TARGET_SESSION=$(tmux display-message -p "#{session_name}")

LOG_DIR="${HOME}/.local/share/opencode/log"
TEST_LOG="/tmp/oc-test-notify-$$.log"

# ─── Helpers ──────────────────────────────────────────────────────────────────
# Fire the notification directly (same logic as opencode-notify, no detection)
fire_notification() {
  local q="${1:-$QUESTION}"

  say "Firing notification…"
  info "session=${TARGET_SESSION}  window=${TARGET_WINDOW}  pane=${PANE_ID}"

  # BEL on the pane tty
  local pane_tty
  pane_tty=$(tmux display-message -pt "${PANE_ID}" "#{pane_tty}" 2>/dev/null || echo "")
  if [[ -n "$pane_tty" && -w "$pane_tty" ]]; then
    printf '\a' >> "$pane_tty" 2>/dev/null && info "BEL sent to ${pane_tty}"
  fi

  # tmux status-bar popup
  local short="${q:0:72}"; [[ "${#q}" -gt 72 ]] && short="${short}…"
  tmux display-message -d 8000 \
    " 󰘦  opencode [win:${TARGET_WINDOW}] ⌨  ${short}" 2>/dev/null \
    && info "tmux display-message sent"

  # Desktop notification
  if command -v notify-send &>/dev/null; then
    notify-send --urgency=normal --expire-time=8000 \
      --app-name="opencode" "󰘦 opencode — question" "${q}" 2>/dev/null \
      && info "notify-send sent"
  else
    info "notify-send not available (skipped)"
  fi

  ok "Notification fired"
}

# ─── Method: Direct ───────────────────────────────────────────────────────────
test_direct() {
  say "METHOD: direct — fires notification immediately without any detection"
  echo
  printf "  ${C_DIM}Question: ${C_RESET}${QUESTION}\n"
  echo
  info "Switch to another tmux window NOW to see the notification (${NOTIFY_WAIT}s)…"
  sleep "$NOTIFY_WAIT"
  fire_notification "$QUESTION"
}

# ─── Method: Log ──────────────────────────────────────────────────────────────
test_log() {
  say "METHOD: log — writes a fake opencode log entry, then starts opencode-notify"
  echo

  # Enable activity monitoring on the window
  tmux set-window-option -t "${TARGET_SESSION}:${TARGET_WINDOW}" monitor-activity on 2>/dev/null || true

  # Start opencode-notify in the background, pointing it at this pane
  say "Starting opencode-notify background watcher…"
  opencode-notify "$PANE_ID" "$TARGET_SESSION" "$TARGET_WINDOW" &
  local notify_pid=$!
  info "opencode-notify PID: ${notify_pid}"

  # Give the watcher a moment to start up
  sleep 2

  # Create a fake log file that looks like opencode's real log format
  mkdir -p "$LOG_DIR"
  local fake_log="${LOG_DIR}/$(date +%Y-%m-%dT%H%M%S)-test.log"
  info "Creating fake log: ${fake_log}"

  # Write an initial entry (looks like startup)
  echo "INFO  $(date -u +%Y-%m-%dT%H:%M:%S) +0ms service=default version=test args=[] opencode" \
    >> "$fake_log"

  say "Switch to another tmux window NOW (${NOTIFY_WAIT}s)…"
  info "Will then write the question tool log entry"
  sleep "$NOTIFY_WAIT"

  # Write the question tool invocation log entry
  echo "INFO  $(date -u +%Y-%m-%dT%H:%M:%S) +0ms service=tool toolName=question state=call question=\"${QUESTION}\"" \
    >> "$fake_log"
  ok "Fake log entry written → opencode-notify should detect and notify"

  # Wait for detection
  sleep 3

  # Cleanup
  kill "$notify_pid" 2>/dev/null || true
  rm -f "$fake_log"
  info "Cleanup done"
}

# ─── Method: Pane ─────────────────────────────────────────────────────────────
test_pane() {
  say "METHOD: pane — prints the question prompt pattern to this terminal"
  echo
  info "opencode-notify will capture this pane's content and detect the prompt"

  # Enable activity monitoring
  tmux set-window-option -t "${TARGET_SESSION}:${TARGET_WINDOW}" monitor-activity on 2>/dev/null || true

  # Start opencode-notify
  say "Starting opencode-notify background watcher…"
  opencode-notify "$PANE_ID" "$TARGET_SESSION" "$TARGET_WINDOW" &
  local notify_pid=$!
  info "opencode-notify PID: ${notify_pid}"

  sleep 2

  say "Switch to another tmux window NOW (${NOTIFY_WAIT}s)…"
  info "Will then render the question prompt pattern"
  sleep "$NOTIFY_WAIT"

  # Render the question prompt exactly as opencode does it
  # (cyan ? + bold question text + gray > input indicator)
  printf '\033[36m?\033[0m \033[1m%s\033[0m\n' "${QUESTION}"
  printf '\033[2m> \033[0m'

  ok "Question prompt rendered — waiting for detection (5s)…"
  sleep 5

  # Clear the prompt (simulate user answering)
  printf '\r\033[K'

  # Cleanup
  kill "$notify_pid" 2>/dev/null || true
  info "Cleanup done"
}

# ─── Method: ACP ──────────────────────────────────────────────────────────────
test_acp() {
  say "METHOD: acp — starts a fake ACP HTTP server that emits a question SSE event"
  echo

  command -v python3 &>/dev/null || { warn "python3 not found, skipping ACP test"; return 1; }

  # Find a free port
  local port=18765

  # Create a minimal Python SSE server that speaks the opencode ACP protocol
  local srv_script="/tmp/oc-test-acp-srv-$$.py"
  cat > "$srv_script" <<'PYEOF'
import http.server, json, time, sys, threading, os

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 18765
QUESTION = sys.argv[2] if len(sys.argv) > 2 else "Test question from fake ACP server"
DELAY = float(sys.argv[3]) if len(sys.argv) > 3 else 3.0

class ACPHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # silence access logs

    def do_HEAD(self):
        if self.path == "/api/event":
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.end_headers()

    def do_GET(self):
        if self.path == "/api/event":
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.end_headers()
            try:
                # Keep-alive ping
                self.wfile.write(b": keep-alive\n\n")
                self.wfile.flush()
                time.sleep(DELAY)
                # Emit the question tool event
                event = {
                    "type": "message.part.updated",
                    "part": {
                        "type": "tool-invocation",
                        "toolName": "question",
                        "state": "call",
                        "args": {"question": QUESTION}
                    }
                }
                payload = f"data: {json.dumps(event)}\n\n"
                self.wfile.write(payload.encode())
                self.wfile.flush()
                # Hold the connection open briefly
                time.sleep(10)
            except BrokenPipeError:
                pass
        else:
            self.send_response(404)
            self.end_headers()

with http.server.HTTPServer(("127.0.0.1", PORT), ACPHandler) as srv:
    print(f"ACP test server on port {PORT}", flush=True)
    # Auto-shutdown after 30s
    timer = threading.Timer(30, srv.shutdown)
    timer.start()
    srv.serve_forever()
    timer.cancel()
PYEOF

  # Enable activity monitoring
  tmux set-window-option -t "${TARGET_SESSION}:${TARGET_WINDOW}" monitor-activity on 2>/dev/null || true

  # Start the fake ACP server
  say "Starting fake ACP server on port ${port}…"
  python3 "$srv_script" "$port" "$QUESTION" "$NOTIFY_WAIT" &
  local srv_pid=$!
  info "Fake ACP server PID: ${srv_pid}"
  sleep 1  # let the server bind

  # Start opencode-notify — BUT it discovers ports via ss, so we need to
  # register our fake server's port.  We fake-inject the PID via a wrapper.
  # Simplest approach: directly call watch_acp by sourcing the notify script
  # in a subshell and calling only that function.

  # Since direct sourcing is complex, we use curl to subscribe ourselves
  # and relay the notification
  say "Subscribing to fake ACP SSE stream…"
  say "Switch to another tmux window NOW (will emit event in ${NOTIFY_WAIT}s)…"

  local pane_tty short
  pane_tty=$(tmux display-message -pt "${PANE_ID}" "#{pane_tty}" 2>/dev/null || echo "")
  short="${QUESTION:0:72}"; [[ "${#QUESTION}" -gt 72 ]] && short="${short}…"

  curl -sSfN --no-buffer \
    -H "Accept: text/event-stream" \
    -H "Cache-Control: no-cache" \
    --max-time 20 \
    "http://127.0.0.1:${port}/api/event" 2>/dev/null \
  | while IFS= read -r line; do
      [[ "$line" == data:* ]] || continue
      local data="${line#data: }"
      if echo "$data" | grep -qiE '"toolName"\s*:\s*"question".*"state"\s*:\s*"call"'; then
        # Notification
        [[ -n "$pane_tty" && -w "$pane_tty" ]] && printf '\a' >> "$pane_tty"
        tmux display-message -d 8000 \
          " 󰘦  opencode [win:${TARGET_WINDOW}] ⌨  ${short}" 2>/dev/null || true
        command -v notify-send &>/dev/null && \
          notify-send --urgency=normal --expire-time=8000 \
            --app-name="opencode" "󰘦 opencode — question (ACP test)" \
            "${QUESTION}" 2>/dev/null || true
        ok "ACP event received → notification fired"
        break
      fi
    done

  kill "$srv_pid" 2>/dev/null || true
  rm -f "$srv_script"
}

# ─── Full Test Suite ──────────────────────────────────────────────────────────
test_all() {
  echo
  printf "${C_BOLD}${C_CYAN}╔══════════════════════════════════════════════════╗${C_RESET}\n"
  printf "${C_BOLD}${C_CYAN}║   opencode question-tool notification test       ║${C_RESET}\n"
  printf "${C_BOLD}${C_CYAN}╚══════════════════════════════════════════════════╝${C_RESET}\n"
  echo
  info "session=${TARGET_SESSION}  window=${TARGET_WINDOW}  pane=${PANE_ID}"
  echo
  say "This will run three tests, each with a ${NOTIFY_WAIT}s countdown."
  say "TIP: switch to a different tmux window during the countdowns!"
  echo
  printf "  Press ${C_BOLD}Enter${C_RESET} to begin … "
  read -r

  echo
  say "═══ TEST 1/3 — Direct notification ═══"
  test_direct
  sleep 2

  echo
  say "═══ TEST 2/3 — Log file detection ═══"
  test_log
  sleep 2

  echo
  say "═══ TEST 3/3 — Pane content detection ═══"
  test_pane
  sleep 2

  echo
  printf "${C_GREEN}${C_BOLD}All tests complete.${C_RESET}\n"
  echo
  say "To verify ACP detection independently, run:  opencode-test-question --acp"
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
case "$METHOD" in
  direct) test_direct ;;
  log)    test_log    ;;
  pane)   test_pane   ;;
  acp)    test_acp    ;;
  all)    test_all    ;;
esac
