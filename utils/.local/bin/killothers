#!/usr/bin/env bash
# killothers - Encerra processos de outros usuários, preservando o usuário atual
# Uso: killothers [--dry-run] [--force] [--signal SIGNAL] [--help]

set -uo pipefail

# ── Cores ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# ── Defaults ───────────────────────────────────────────────────────────────────
DRY_RUN=false
FORCE=false
SIGNAL="TERM"
CURRENT_USER="$(id -un)"
CURRENT_UID="$(id -u)"

# Processos críticos do sistema — nunca serão encerrados
CRITICAL_PROCESSES=(
  systemd kernel kthreadd init journald sshd
  udevd dbus-daemon polkitd cron crond
  login agetty getty NetworkManager wpa_supplicant
  auditd rsyslogd syslogd irqbalance thermald
)

# ── Args ───────────────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case $1 in
    --dry-run|-n)   DRY_RUN=true ;;
    --force|-f)     FORCE=true ;;
    --signal|-s)    SIGNAL="${2:-TERM}"; shift ;;
    --help|-h)
      printf "Uso: killothers [OPÇÕES]\n\n"
      printf "Encerra todos os processos de usuários diferentes do usuário atual (%s).\n\n" "$CURRENT_USER"
      printf "Opções:\n"
      printf "  -n, --dry-run        Apenas lista os processos, não os encerra\n"
      printf "  -f, --force          Usa SIGKILL imediatamente (sem tentar SIGTERM antes)\n"
      printf "  -s, --signal SIG     Sinal inicial (padrão: TERM). Ex: KILL, HUP, INT\n"
      printf "  -h, --help           Exibe esta ajuda\n\n"
      printf "Exemplos:\n"
      printf "  killothers              # Encerra processos de outros usuários (TERM → KILL)\n"
      printf "  killothers --dry-run    # Apenas lista sem encerrar\n"
      printf "  killothers --force      # Encerra imediatamente com SIGKILL\n"
      exit 0 ;;
    *) printf "${RED}Opção desconhecida: %s. Use --help${RESET}\n" "$1"; exit 1 ;;
  esac
  shift
done

# ── Verificação de permissões ──────────────────────────────────────────────────
if [[ "$CURRENT_UID" -ne 0 ]]; then
  printf "${YELLOW}${BOLD}Aviso:${RESET}${YELLOW} Executando sem root. Apenas processos do mesmo grupo de permissões\n"
  printf "       podem ser encerrados. Use 'sudo killothers' para encerrar todos.${RESET}\n\n"
fi

# ── Checa se nome é processo crítico ──────────────────────────────────────────
is_critical() {
  local name="$1"
  local pid="$2"

  # PIDs do sistema (kernel threads) — sempre protegidos
  (( pid <= 2 )) && return 0

  for crit in "${CRITICAL_PROCESSES[@]}"; do
    [[ "$name" == "$crit" ]] && return 0
  done
  return 1
}

# ── Coleta processos de outros usuários ───────────────────────────────────────
declare -a OTHER_PIDS OTHER_USERS OTHER_NAMES OTHER_MEMS

while IFS= read -r line; do
  read -r u pid mem cmd <<< "$line"
  [[ "$u" == "$CURRENT_USER" ]] && continue
  [[ "$u" == "root" && "$CURRENT_UID" -ne 0 ]] && continue  # sem root, pula processos de root

  local_name="${cmd##*/}"
  local_name="${local_name%%[[:space:]]*}"

  OTHER_PIDS+=("$pid")
  OTHER_USERS+=("$u")
  OTHER_NAMES+=("$local_name")
  OTHER_MEMS+=("$mem")
done < <(ps aux --sort=-%cpu | awk 'NR>1 {print $1, $2, $4, $11}')

# ── Sem processos encontrados ──────────────────────────────────────────────────
if [[ ${#OTHER_PIDS[@]} -eq 0 ]]; then
  printf "${GREEN}Nenhum processo de outro usuário encontrado.${RESET}\n"
  exit 0
fi

# ── Cabeçalho ─────────────────────────────────────────────────────────────────
printf "\n${BOLD}${CYAN}══ KILLOTHERS ════════════════════════════════════════════════════${RESET}\n"
printf "  Usuário atual : ${BOLD}%s${RESET}\n" "$CURRENT_USER"
  if $DRY_RUN; then
    printf "  Modo          : ${YELLOW}DRY-RUN (nada será encerrado)${RESET}\n"
  else
    printf "  Modo          : ${RED}ATIVO${RESET}\n"
  fi
printf "  Sinal         : %s\n\n" "$SIGNAL"

printf "${BOLD}%-8s %-14s %-8s %6s   %-35s${RESET}\n" "STATUS" "USUARIO" "PID" "CPU%" "PROCESSO"
printf "${DIM}%s${RESET}\n" "────────────────────────────────────────────────────────────────────────────"

killed=0
skipped=0
failed=0

for (( i=0; i<${#OTHER_PIDS[@]}; i++ )); do
  pid="${OTHER_PIDS[$i]}"
  user="${OTHER_USERS[$i]}"
  name="${OTHER_NAMES[$i]}"
  mem="${OTHER_MEMS[$i]}"

  # Verifica se processo ainda existe
  kill -0 "$pid" 2>/dev/null || continue

  if is_critical "$name" "$pid"; then
    printf "  ${DIM}%-6s${RESET}  ${DIM}%-14s %-8s %5s%%   %-35s [crítico, ignorado]${RESET}\n" \
      "SKIP" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
    (( skipped++ ))
    continue
  fi

  if $DRY_RUN; then
    printf "  ${YELLOW}%-6s${RESET}  %-14s %-8s %5s%%   %-35s\n" \
      "DRY" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
    (( killed++ ))
    continue
  fi

  # Tenta encerrar
  if $FORCE; then
    # SIGKILL direto
    if kill -KILL "$pid" 2>/dev/null; then
      printf "  ${RED}%-6s${RESET}  %-14s %-8s %5s%%   %-35s\n" \
        "KILL" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
      (( killed++ ))
    else
      printf "  ${YELLOW}%-6s${RESET}  %-14s %-8s %5s%%   %-35s [sem permissão]\n" \
        "DENY" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
      (( failed++ ))
    fi
  else
    # SIGTERM → aguarda → SIGKILL se persistir
    if kill -"$SIGNAL" "$pid" 2>/dev/null; then
      sleep 1
      if kill -0 "$pid" 2>/dev/null; then
        # Processo resistiu — força SIGKILL
        if kill -KILL "$pid" 2>/dev/null; then
          printf "  ${RED}%-6s${RESET}  %-14s %-8s %5s%%   %-35s [KILL forçado]\n" \
            "KILL" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
        else
          printf "  ${YELLOW}%-6s${RESET}  %-14s %-8s %5s%%   %-35s [resistiu ao KILL]\n" \
            "STUCK" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
          (( failed++ ))
          continue
        fi
      else
        printf "  ${GREEN}%-6s${RESET}  %-14s %-8s %5s%%   %-35s\n" \
          "TERM" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
      fi
      (( killed++ ))
    else
      printf "  ${YELLOW}%-6s${RESET}  %-14s %-8s %5s%%   %-35s [sem permissão]\n" \
        "DENY" "${user:0:14}" "$pid" "$mem" "${name:0:35}"
      (( failed++ ))
    fi
  fi
done

# ── Resumo ─────────────────────────────────────────────────────────────────────
printf "${DIM}%s${RESET}\n" "────────────────────────────────────────────────────────────────────────────"
if $DRY_RUN; then
  printf "\n${YELLOW}${BOLD}Dry-run:${RESET} %d processo(s) seriam encerrados. Reexecute sem --dry-run para confirmar.\n\n" "$killed"
else
  printf "\n${BOLD}Resumo:${RESET}  ${GREEN}%d encerrado(s)${RESET}  |  ${YELLOW}%d ignorado(s)${RESET}  |  ${RED}%d falha(s)${RESET}\n\n" \
    "$killed" "$skipped" "$failed"
  (( failed > 0 )) && printf "${DIM}Dica: use 'sudo killothers' para encerrar processos sem permissão.${RESET}\n\n"
fi
