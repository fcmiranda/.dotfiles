#!/usr/bin/env bash
# perf-toggle — set or toggle the ACPI platform profile
#
# Usage:
#   perf-toggle                  # toggle: balanced ↔ performance (waybar click)
#   perf-toggle balanced         # set balanced
#   perf-toggle performance      # set performance (AC only)
#   perf-toggle low-power        # set eco / low-power
#
# Sends a mako notification and signals waybar (signal 12) on change.

set -euo pipefail

PROFILE_PATH="/sys/firmware/acpi/platform_profile"

current=$(cat "$PROFILE_PATH" 2>/dev/null || echo balanced)
on_ac=$(cat /sys/class/power_supply/*/online 2>/dev/null | head -1 || echo 0)

_set_profile() {
  local profile="$1"
  local icon label

  case "$profile" in
    performance) icon="󰓅" ; label="Performance mode" ;;
    low-power)   icon="󰌪" ; label="Eco / low-power mode" ;;
    balanced)    icon="󰌪" ; label="Balanced mode" ;;
    *)           icon=""   ; label="$profile" ;;
  esac

  echo "$profile" | sudo tee "$PROFILE_PATH" > /dev/null
  notify-send -t 2000 "${icon} Power profile" "$label" 2>/dev/null || true
  pkill -RTMIN+12 waybar 2>/dev/null || true
}

# ── Explicit profile argument ─────────────────────────────────────────────────
if [[ $# -ge 1 ]]; then
  requested="$1"
  if [[ "$requested" == "performance" && "$on_ac" != "1" ]]; then
    notify-send -t 3000 "󱐋 Power profile" "Performance on battery drains quickly" 2>/dev/null || true
  fi
  _set_profile "$requested"
  exit 0
fi

# ── No argument: toggle balanced ↔ performance (waybar click) ─────────────────
if [[ "$current" == "performance" ]]; then
  _set_profile "balanced"
else
  if [[ "$on_ac" == "1" ]]; then
    _set_profile "performance"
  else
    notify-send -t 2000 "󰤇 Power profile" "On battery — switching to balanced" 2>/dev/null || true
    _set_profile "balanced"
  fi
fi
