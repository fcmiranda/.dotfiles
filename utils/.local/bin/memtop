#!/usr/bin/env bash
# memtop - Analisador e gerenciador interativo de memória
# Uso: memtop [--kill] [--report] [--watch] [--top N]

set -uo pipefail

# ── Cores ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# ── Defaults ───────────────────────────────────────────────────────────────────
TOP_N=15
KILL_MODE=false
WATCH_MODE=false
REPORT_MODE=false
REPORT_FILE="$HOME/memory-report-$(date +%Y%m%d-%H%M%S).md"

# ── Args ───────────────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case $1 in
    --kill|-k)     KILL_MODE=true ;;
    --report|-r)   REPORT_MODE=true ;;
    --watch|-w)    WATCH_MODE=true ;;
    --top|-t)      TOP_N="${2:-15}"; shift ;;
    --help|-h)
      echo "Uso: memtop [--kill] [--report] [--watch] [--top N]"
      echo "  --kill    Modo interativo para encerrar processos"
      echo "  --report  Gera relatório markdown em ~/memory-report-*.md"
      echo "  --watch   Atualiza a cada 3s (pressione Ctrl+C para sair)"
      echo "  --top N   Mostra os N processos mais pesados (padrão: 15)"
      exit 0 ;;
    *) echo "Opção desconhecida: $1. Use --help"; exit 1 ;;
  esac
  shift
done

# ── Funções auxiliares ─────────────────────────────────────────────────────────
bytes_to_human() {
  local kb=$1
  if   (( kb >= 1048576 )); then
    local int=$(( kb / 1048576 ))
    local dec=$(( (kb % 1048576) * 10 / 1048576 ))
    printf "%d.%d GB" "$int" "$dec"
  elif (( kb >= 1024 )); then
    local int=$(( kb / 1024 ))
    local dec=$(( (kb % 1024) * 10 / 1024 ))
    printf "%d.%d MB" "$int" "$dec"
  else
    printf "%d KB" "$kb"
  fi
}

bar() {
  local pct=$1 width=${2:-20}
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local color
  (( pct >= 85 )) && color=$RED || { (( pct >= 60 )) && color=$YELLOW || color=$GREEN; }
  printf "${color}%s${DIM}%s${RESET}" "$(printf '█%.0s' $(seq 1 $filled 2>/dev/null || true))" \
                                        "$(printf '░%.0s' $(seq 1 $empty  2>/dev/null || true))"
}

# Fallback para bar() sem seq pipe problems
draw_bar() {
  local pct=$1 width=${2:-20}
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local color bar_str=""
  (( pct >= 85 )) && color=$RED || { (( pct >= 60 )) && color=$YELLOW || color=$GREEN; }
  local i
  for (( i=0; i<filled; i++ )); do bar_str+="█"; done
  for (( i=0; i<empty;  i++ )); do bar_str+="░"; done
  printf "${color}%s${RESET}" "$bar_str"
}

# ── Leitura de memória ─────────────────────────────────────────────────────────
read_mem() {
  declare -gA MEM
  while IFS=: read -r key val; do
    key="${key// /}"
    val="${val//[[:space:]]kB/}"
    val="${val// /}"
    MEM[$key]=$val
  done < /proc/meminfo
}

# ── Cabeçalho de resumo ────────────────────────────────────────────────────────
print_summary() {
  read_mem
  local total=${MEM[MemTotal]}
  local free=${MEM[MemFree]}
  local avail=${MEM[MemAvailable]}
  local buffers=${MEM[Buffers]}
  local cached=${MEM[Cached]}
  local swap_total=${MEM[SwapTotal]}
  local swap_free=${MEM[SwapFree]}
  local shmem=${MEM[Shmem]}

  local used=$(( total - free - buffers - cached - shmem ))
  local used_pct=$(( used * 100 / total ))
  local swap_used=$(( swap_total - swap_free ))
  local swap_pct=0
  (( swap_total > 0 )) && swap_pct=$(( swap_used * 100 / swap_total ))

  printf "\n${BOLD}${CYAN}══ RESUMO DE MEMÓRIA ═══════════════════════════════════════════${RESET}\n"
  printf "  ${BOLD}RAM Total :${RESET} %-10s  ${BOLD}Usada :${RESET} %-10s  ${BOLD}Disponível :${RESET} %s\n" \
    "$(bytes_to_human $total)" "$(bytes_to_human $used)" "$(bytes_to_human $avail)"
  printf "  ${BOLD}Buffers   :${RESET} %-10s  ${BOLD}Cache :${RESET} %-10s  ${BOLD}Shared     :${RESET} %s\n" \
    "$(bytes_to_human $buffers)" "$(bytes_to_human $cached)" "$(bytes_to_human $shmem)"
  printf "\n  RAM  [%s] %d%%\n" "$(draw_bar $used_pct)" $used_pct
  printf "  SWAP [%s] %d%%  (%s / %s)\n\n" \
    "$(draw_bar $swap_pct)" $swap_pct "$(bytes_to_human $swap_used)" "$(bytes_to_human $swap_total)"

  # Alertas
  if (( swap_pct >= 95 )); then
    printf "  ${RED}${BOLD}⚠  SWAP CRÍTICO (%d%%) — sistema pode travar por falta de swap!${RESET}\n\n" $swap_pct
  elif (( swap_pct >= 70 )); then
    printf "  ${YELLOW}${BOLD}⚠  Uso de SWAP elevado (%d%%) — possível lentidão!${RESET}\n\n" $swap_pct
  fi
  if (( used_pct >= 90 )); then
    printf "  ${RED}${BOLD}⚠  RAM CRÍTICA (%d%%) — risco de OOM killer!${RESET}\n\n" $used_pct
  fi
}

# ── Tabela de processos ────────────────────────────────────────────────────────
print_processes() {
  local n=${1:-$TOP_N}
  printf "${BOLD}${CYAN}══ TOP %d PROCESSOS POR MEMÓRIA ═══════════════════════════════════${RESET}\n" $n
  printf "${BOLD}%-5s %-12s %-8s %8s %8s %8s   %-30s${RESET}\n" \
    "RANK" "USER" "PID" "RSS" "SWAP" "MEM%" "COMANDO"
  printf "${DIM}%s${RESET}\n" "────────────────────────────────────────────────────────────────────────────"

  local rank=0
  ps aux --sort=-%mem | awk 'NR>1' | head -"$n" | while read -r user pid cpu mem vsz rss tty stat start time cmd rest; do
    rank=$(( rank + 1 ))

    # RSS em kB
    local rss_kb=$(( rss ))
    local rss_h; rss_h=$(bytes_to_human $rss_kb)

    # Swap do processo via /proc
    local swap_kb=0
    if [[ -r /proc/$pid/status ]]; then
      swap_kb=$(awk '/VmSwap/{print $2}' /proc/$pid/status 2>/dev/null || echo 0)
      swap_kb=${swap_kb:-0}
    fi
    local swap_h; swap_h=$(bytes_to_human $swap_kb)

    # Nome curto
    local name="${cmd##*/}"
    name="${name:0:30}"

    # Cor por uso
    local color=$RESET
    (( rss_kb > 200000 )) && color=$RED || { (( rss_kb > 80000 )) && color=$YELLOW || color=; }

    printf "${color}%-5s %-12s %-8s %8s %8s %5s%%   %-30s${RESET}\n" \
      "$rank" "${user:0:12}" "$pid" "$rss_h" "$swap_h" "$mem" "$name"
  done
}

# ── Agrupamento por app ────────────────────────────────────────────────────────
print_grouped() {
  printf "\n${BOLD}${CYAN}══ MEMÓRIA POR APLICAÇÃO (agrupado) ═══════════════════════════════${RESET}\n"
  printf "${BOLD}%-22s %10s %8s %6s${RESET}\n" "APLICAÇÃO" "RSS TOTAL" "CPU%" "PROCS"
  printf "${DIM}%s${RESET}\n" "──────────────────────────────────────────────────────"

  ps aux --sort=-%mem | awk 'NR>1 {
    cmd=$11; gsub(/.*\//,"",cmd);
    if (cmd ~ /chrome|chromium/) cmd="chrome";
    if (cmd ~ /firefox/) cmd="firefox";
    mem[cmd]+=$6; cpu[cmd]+=$3; count[cmd]++
  } END {
    for(c in mem) printf "%s\t%.0f\t%.1f\t%d\n", c, mem[c], cpu[c], count[c]
  }' | sort -t$'\t' -k2 -rn | head -12 | while IFS=$'\t' read -r name rss_kb cpu procs; do
    local rss_h; rss_h=$(bytes_to_human "$rss_kb")
    local color=$RESET
    (( rss_kb > 500000 )) && color=$RED || { (( rss_kb > 150000 )) && color=$YELLOW || color=; }
    printf "${color}%-22s %10s %7.1f%% %5d${RESET}\n" "$name" "$rss_h" "$cpu" "$procs"
  done
}

# ── Modo kill interativo ───────────────────────────────────────────────────────
interactive_kill() {
  echo ""
  printf "${YELLOW}${BOLD}══ MODO ENCERRAMENTO INTERATIVO ══════════════════════════════════${RESET}\n"
  printf "${DIM}Lista os processos. Você escolhe quais encerrar.${RESET}\n\n"

  # Monta array de processos
  local -a pids names mems users
  while IFS= read -r line; do
    local user pid mem cmd
    read -r user pid _ mem _ _ _ _ _ _ cmd _ <<< "$line"
    pids+=("$pid")
    names+=("${cmd##*/}")
    mems+=("$mem")
    users+=("$user")
  done < <(ps aux --sort=-%mem | awk 'NR>1' | head -20)

  local i
  for (( i=0; i<${#pids[@]}; i++ )); do
    printf "  ${BOLD}[%2d]${RESET} %-8s PID:%-8s MEM:%5s%%  %s\n" \
      $(( i+1 )) "${users[$i]:0:8}" "${pids[$i]}" "${mems[$i]}" "${names[$i]:0:35}"
  done

  echo ""
  printf "${BOLD}Digite o(s) número(s) para encerrar (ex: 1 3 5), ou 'q' para sair:${RESET} "
  read -r choices

  [[ "$choices" == "q" || -z "$choices" ]] && { echo "Cancelado."; return; }

  for choice in $choices; do
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#pids[@]} )); then
      local idx=$(( choice - 1 ))
      local pid="${pids[$idx]}"
      local name="${names[$idx]}"
      local user="${users[$idx]}"

      # Proteção: não matar processos críticos do sistema
      if [[ "$name" =~ ^(systemd|kernel|kthreadd|init|journald|sshd)$ ]]; then
        printf "  ${RED}✗ Recusado: '%s' é um processo crítico do sistema.${RESET}\n" "$name"
        continue
      fi

      printf "  Encerrando PID %s (%s) do usuário %s... " "$pid" "$name" "$user"
      if kill -TERM "$pid" 2>/dev/null; then
        sleep 1
        if kill -0 "$pid" 2>/dev/null; then
          kill -KILL "$pid" 2>/dev/null && printf "${RED}[KILL forçado]${RESET}\n" || printf "${YELLOW}[resistiu]${RESET}\n"
        else
          printf "${GREEN}[encerrado]${RESET}\n"
        fi
      else
        printf "${RED}[sem permissão — tente com sudo]${RESET}\n"
      fi
    else
      printf "  ${YELLOW}Número inválido: %s${RESET}\n" "$choice"
    fi
  done
}

# ── Geração de relatório markdown ─────────────────────────────────────────────
generate_report() {
  local file="${1:-$REPORT_FILE}"
  read_mem

  local total=${MEM[MemTotal]}
  local free=${MEM[MemFree]}
  local avail=${MEM[MemAvailable]}
  local cached=${MEM[Cached]}
  local buffers=${MEM[Buffers]}
  local shmem=${MEM[Shmem]}
  local swap_total=${MEM[SwapTotal]}
  local swap_free=${MEM[SwapFree]}
  local used=$(( total - free - buffers - cached - shmem ))
  local swap_used=$(( swap_total - swap_free ))
  local swap_pct=0
  (( swap_total > 0 )) && swap_pct=$(( swap_used * 100 / swap_total ))
  local used_pct=$(( used * 100 / total ))
  local date_now; date_now=$(date '+%Y-%m-%d %H:%M:%S')
  local uptime_str; uptime_str=$(uptime -p)
  local load; load=$(uptime | grep -oP 'load average: \K.*')
  local cpu_model; cpu_model=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
  local cpu_count; cpu_count=$(nproc)
  local hostname_str; hostname_str=$(hostname)

  # Pre-calculate human-readable strings (bytes_to_human not available in heredoc subshells)
  local h_total;     h_total=$(bytes_to_human "$total")
  local h_swap_tot;  h_swap_tot=$(bytes_to_human "$swap_total")
  local h_used;      h_used=$(bytes_to_human "$used")
  local h_avail;     h_avail=$(bytes_to_human "$avail")
  local h_cached;    h_cached=$(bytes_to_human "$cached")
  local h_buffers;   h_buffers=$(bytes_to_human "$buffers")
  local h_shmem;     h_shmem=$(bytes_to_human "$shmem")
  local h_swap_used; h_swap_used=$(bytes_to_human "$swap_used")
  local h_swap_free; h_swap_free=$(bytes_to_human "$swap_free")
  local avail_pct=$(( avail * 100 / total ))
  local cached_pct=$(( cached * 100 / total ))

  cat > "$file" <<MARKDOWN
# Relatório de Análise de Memória

**Gerado em:** $date_now  
**Host:** $hostname_str  
**Uptime:** $uptime_str  
**Load Average:** $load

---

## Hardware

| Item | Valor |
|------|-------|
| CPU | $cpu_model |
| Cores | $cpu_count |
| RAM Total | $h_total |
| SWAP Total | $h_swap_tot |

---

## Estado Atual da Memória

| Métrica | Valor | % do Total |
|---------|-------|-----------|
| RAM Usada (real) | $h_used | ${used_pct}% |
| RAM Disponível | $h_avail | ${avail_pct}% |
| Cache de disco | $h_cached | ${cached_pct}% |
| Buffers | $h_buffers | — |
| Shared (tmpfs) | $h_shmem | — |
| SWAP Usada | $h_swap_used | ${swap_pct}% do swap |
| SWAP Livre | $h_swap_free | — |

MARKDOWN

  # Nível de alerta
  if (( swap_pct >= 95 )); then
    cat >> "$file" <<MARKDOWN
> [!CAUTION]
> **SWAP CRÍTICO (${swap_pct}%):** A swap está praticamente esgotada. O sistema está
> usando disco como RAM, o que causa lentidão severa e risco de congelamento (OOM kill).

MARKDOWN
  elif (( swap_pct >= 70 )); then
    cat >> "$file" <<MARKDOWN
> [!WARNING]
> **Swap elevado (${swap_pct}%):** Parte da memória foi movida para disco.
> Isso indica pressão de RAM e pode causar lentidão perceptível.

MARKDOWN
  fi

  cat >> "$file" <<MARKDOWN

---

## Top $TOP_N Processos por Consumo de RAM

| # | PID | Usuário | RSS | SWAP | MEM% | Processo |
|---|-----|---------|-----|------|------|---------|
MARKDOWN

  local rank=0
  ps aux --sort=-%mem | awk 'NR>1' | head -"$TOP_N" | while read -r user pid cpu mem vsz rss tty stat start time cmd rest; do
    rank=$(( rank + 1 ))
    local swap_kb=0
    [[ -r /proc/$pid/status ]] && swap_kb=$(awk '/VmSwap/{print $2}' /proc/$pid/status 2>/dev/null || echo 0)
    swap_kb=${swap_kb:-0}
    local name="${cmd##*/}"
    printf "| %d | %s | %s | %s | %s | %s%% | \`%s\` |\n" \
      "$rank" "$pid" "${user:0:12}" "$(bytes_to_human $rss)" "$(bytes_to_human $swap_kb)" "$mem" "${name:0:40}"
  done >> "$file"

  cat >> "$file" <<MARKDOWN

---

## Memória por Aplicação (Agrupado)

| Aplicação | RSS Total | CPU% | Processos |
|-----------|-----------|------|-----------|
MARKDOWN

  ps aux --sort=-%mem | awk 'NR>1 {
    cmd=$11; gsub(/.*\//,"",cmd);
    if (cmd ~ /chrome|chromium/) cmd="chrome";
    if (cmd ~ /firefox/) cmd="firefox";
    mem[cmd]+=$6; cpu[cmd]+=$3; count[cmd]++
  } END {
    for(c in mem) printf "%s\t%.0f\t%.1f\t%d\n", c, mem[c], cpu[c], count[c]
  }' | sort -t$'\t' -k2 -rn | head -15 | while IFS=$'\t' read -r name rss_kb cpu procs; do
    printf "| \`%s\` | %s | %.1f%% | %d |\n" "$name" "$(bytes_to_human $rss_kb)" "$cpu" "$procs"
  done >> "$file"

  cat >> "$file" <<MARKDOWN

---

## Diagnóstico e Causas Identificadas

MARKDOWN

  # Chrome
  local chrome_count; chrome_count=$(ps aux | grep -c "[c]hrome")
  local chrome_rss; chrome_rss=$(ps aux | awk '/chrome/{sum+=$6} END{printf "%.0f", sum}')
  if (( chrome_rss > 300000 )); then
    local chrome_rss_h; chrome_rss_h=$(bytes_to_human "$chrome_rss")
    {
      printf '### Google Chrome — Alto consumo multi-processo\n\n'
      printf 'O Chrome usa uma **arquitetura de processo por aba/extensão**. Foram encontrados\n'
      printf '**%s processos** do Chrome consumindo no total **%s**.\n\n' "$chrome_count" "$chrome_rss_h"
      cat <<'EOF'
**Por que acontece:**
- Cada aba, extensão e serviço (rede, GPU, storage) roda em processo isolado
- Abas abertas há muitos dias acumulam memória com vazamentos graduais
- Renderers mantêm cache de JS/DOM mesmo em abas inativas

**Mitigação:**
- Ative "Memory Saver" em `chrome://settings/performance`
- Feche abas não utilizadas ou use extensão como "The Great Suspender"
- Limite extensões ativas

EOF
    } >> "$file"
  fi

  # Swap saturada
  if (( swap_pct >= 70 )); then
    local swap_used_h; swap_used_h=$(bytes_to_human "$swap_used")
    local swap_total_h; swap_total_h=$(bytes_to_human "$swap_total")
    local total_h; total_h=$(bytes_to_human "$total")
    {
      printf '### Swap Saturada — Sistema em Pressão de Memória\n\n'
      printf 'A swap (zram neste sistema) está em **%d%%** de uso (**%s** de **%s**).\n\n' \
        "$swap_pct" "$swap_used_h" "$swap_total_h"
      printf '**Por que acontece:**\n'
      printf '%s\n' "- A RAM física ($total_h) é insuficiente para a carga atual"
      cat <<'EOF'
- Processos em segundo plano por dias foram paginados para swap
- zram comprime dados na RAM, mas tem limite de compressão (~2-3x)
- Com swap esgotada, o kernel aciona o **OOM Killer** encerrando processos

**Mitigação:**
- Reinicializar o sistema libera a swap completamente
- `sudo swapoff -a && sudo swapon -a` recicla a swap (libera páginas ociosas)
- Aumentar RAM física é a solução definitiva para esta configuração

EOF
    } >> "$file"
  fi

  # Uptime longo
  local days; days=$(uptime | grep -oP '\d+(?= day)')
  if [[ -n "$days" ]] && (( days >= 2 )); then
    {
      printf '### Uptime Elevado — %s dias sem reinicialização\n\n' "$days"
      cat <<'EOF'
Sistemas com uptime prolongado acumulam:
- Fragmentação de heap em processos de longa vida
- Vazamentos de memória graduais (especialmente em browsers e Electron apps)
- Aumento gradual do uso de swap por páginas raramente acessadas

**Mitigação:** Reiniciar o sistema periodicamente (a cada 3-7 dias) em máquinas
com RAM limitada é uma prática válida.

EOF
    } >> "$file"
  fi

  cat >> "$file" <<'EOF'
### Serviço `makima.service` em Crash Loop

O serviço `makima` está falhando continuamente (código de saída 101),
gerando dezenas de restarts por hora. Embora o uso de memória de cada instância
seja pequeno (~7 MB), o crash loop causa:
- Ruído no journal do sistema
- Sobrecarga pontual de CPU a cada restart
- Indicativo de configuração incorreta ou dependência ausente

**Verificar:** `systemctl status makima.service` e `journalctl -u makima -n 50`

EOF

  {
    printf '%s\n' '' '---' '' '## Recomendações Prioritárias' ''
    printf '1. **Fechar ou suspender abas do Chrome** — libera centenas de MB imediatamente\n'
    printf '2. **Reciclar a swap:** `sudo swapoff -a && sudo swapon -a`\n'
    printf '3. **Reiniciar o sistema** — único jeito de limpar swap + vazamentos acumulados (%s dias)\n' "$days"
    cat <<'EOF'
4. **Corrigir makima.service** — `journalctl -u makima -n 50` para ver o erro real
5. **Considerar upgrade de RAM** — 3.6 GB é o limite inferior para Chrome + DE pesado

---

## Comandos Úteis

```bash
# Ver processos em tempo real
memtop --watch

# Encerrar processos interativamente
memtop --kill

# Reciclar swap
sudo swapoff -a && sudo swapon -a

# Ver log do makima
journalctl -u makima -n 50 --no-pager

# Chrome com menos memória
google-chrome-stable --js-flags="--max-old-space-size=512"
```

EOF
    printf '\n%s\n%s\n' '---' "*Relatório gerado por \`memtop\` — $(date '+%Y-%m-%d %H:%M:%S')*"
  } >> "$file"

  printf "\n${GREEN}${BOLD}Relatório salvo em: %s${RESET}\n" "$file"
}

# ── Main ───────────────────────────────────────────────────────────────────────
run_once() {
  clear 2>/dev/null || true
  print_summary
  print_processes "$TOP_N"
  print_grouped
  echo ""
}

if $WATCH_MODE; then
  while true; do
    run_once
    printf "${DIM}Atualizando em 3s… Ctrl+C para sair${RESET}\n"
    sleep 3
  done
elif $KILL_MODE; then
  run_once
  interactive_kill
elif $REPORT_MODE; then
  generate_report "$REPORT_FILE"
  run_once
else
  run_once
  printf "${DIM}Dica: use --kill para encerrar processos, --watch para monitorar, --report para gerar relatório${RESET}\n\n"
fi
